# Truck Gate Management System - Apache Configuration

# Prevent directory listing
Options -Indexes

# Enable error documents
ErrorDocument 404 /index.php?page=404
ErrorDocument 403 /index.php?page=403

# Protect sensitive files
<FilesMatch "^(config\.php|README.*\.md|QUICK_SETUP\.md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect database folder
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^database/ - [F,L]
    
    # Rewrite export.xls and export.csv to export.php for browser compatibility
    # This makes the URL appear as .xls/.csv so browsers download it correctly
    RewriteRule ^export\.xls$ export.php [L]
    RewriteRule ^export\.csv$ export.php [L]
</IfModule>

# Set default charset
AddDefaultCharset UTF-8

# Enable GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Set caching for static files
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Force HTTPS (uncomment after SSL is enabled on Hostinger)
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} off
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# Prevent access to .git files
<FilesMatch "^\.git">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Set PHP settings (if allowed by host)
# These are now managed via Hostinger Control Panel
<IfModule mod_php7.c>
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# Custom error pages (optional - create these pages if needed)
# ErrorDocument 500 /error-500.html

